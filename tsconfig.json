{
  "compilerOptions": {
    "outDir": "dist",
    "allowJs": false,
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "moduleResolution": "node16",
    "module": "node16",
    "strict": true,
    "noImplicitAny": false,
    "types": ["node"],
    "esModuleInterop": true,
    "declaration": true
  },
  "include": ["src", "bin"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
